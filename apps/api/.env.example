# NestJS API environment
PORT=3001
WEB_ORIGIN=http://localhost:3000

# Postgres connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Chutes (OpenAI-compatible) LLM - powers the Gioia policy-analysis dashboard
CHUTES_API_KEY=cpk_...
CHUTES_BASE_URL=https://llm.chutes.ai/v1
CHUTES_MODEL=zai-org/GLM-5-Turbo
CODEBOOK_PATH=./data/SkillResilience4EU_Gioia_Master_Codebook.xlsx

# Analysis pipeline: "staged" (multi-call, validated, deterministic ladder) or
# "single" (legacy one-shot fallback). Defaults to "single" if unset.
PIPELINE_MODE=staged

# Model selection (applies in staged mode):
#   claude -> Sonnet 4.6 (extract) + Haiku 4.5 (concepts) + Sonnet 4.6 (reason)  [default]
#   hybrid -> DeepSeek-V3.2 (extract) + Qwen3-32B (concepts) + Opus 4.8 (reason)
#   chutes -> all open models (DeepSeek-V3.2 + Qwen3-32B + GLM-5.2)
MODEL_PROFILE=claude

# How hard Claude "thinks" on the reasoning stages (3-5): low | medium | high | max.
MODEL_EFFORT=medium

# Required for the claude and hybrid profiles.
ANTHROPIC_API_KEY=sk-ant-...

# Optional per-tier overrides (win over the profile). Provider inferred from the id,
# or forced with an "anthropic:" / "chutes:" prefix.
# MODEL_EXTRACT=claude-sonnet-4-6
# MODEL_CONCEPTS=chutes:Qwen/Qwen3-32B-TEE
# MODEL_REASON=claude-opus-4-8

# Better Auth - public sign-up is disabled. The first administrator is created
# from these credentials when the API starts; the administrator creates all
# further accounts from the web app.
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-admin-password
